{
  "name": "praja-dhvani-functions",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud Functions backend for Praja Dhvani: Aadhaar OCR extraction, Gemini classification/clustering/vision/audio-transcription, Cloud Translation. Requires the code-for-community-e2cf2 GCP project on the Blaze plan to deploy.",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions,firestore",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:mock": "ts-node src/scripts/seedMockData.ts",
    "seed:constituencies": "ts-node src/scripts/seedConstituencies.ts",
    "seed:karnataka-officials": "ts-node src/scripts/seedKarnatakaOfficials.ts",
    "seed:wards": "ts-node src/scripts/seedWards.ts"
  },
  "dependencies": {
    "@google-cloud/translate": "^8.5.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.21.0",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@tmcw/togeojson": "^7.1.2",
    "@types/geojson": "^7946.0.16",
    "@types/pdfkit": "^0.17.6",
    "@xmldom/xmldom": "^0.9.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
