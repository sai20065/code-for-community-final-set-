rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // Officials are always scoped to their own constituencyId — see
    // isOfficialForConstituency below, used wherever a ticket's
    // constituencyId is known.
    function isOfficialForConstituency(constituencyId) {
      return isSignedIn() &&
        userDoc(request.auth.uid).role == 'official' &&
        userDoc(request.auth.uid).constituencyId == constituencyId;
    }

    // Identity is Firebase Auth — Anonymous, Phone, or Email/password — a
    // user may only read/write their own profile document, regardless of
    // which sign-in method they used. No Aadhaar number is ever stored
    // here; Aadhaar upload only ever contributes name/address/pincode via a
    // Cloud Function that discards the image immediately.
    match /users/{uid} {
      allow read, create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Citizens create tickets only for their OWN area: the pincode on the
    // new ticket must match their own profile pincode (always present),
    // and if their profile has a resolved constituencyId, that must match
    // too (constituencyId can be null if resolution hasn't happened/found
    // no coverage yet — still allowed, just unscoped until reconciled).
    // The ticket id is generated client-side at creation time so creation
    // must never be blocked by server-side classification state.
    // Officials may only read/update tickets in their OWN constituency.
    // Suggestion (`feedback`) tickets are additionally readable by any
    // citizen in the same constituency — that's the "Trending near you"
    // feed — and any citizen in that constituency may toggle their own
    // support (only the supporterIds/supporterCount fields) on someone
    // else's suggestion, never on a problem report.
    match /submissions/{submissionId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.location.pincode == userDoc(request.auth.uid).pincodeHome &&
        (userDoc(request.auth.uid).constituencyId == null ||
         userDoc(request.auth.uid).constituencyId == request.resource.data.location.constituencyId);
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid ||
         isOfficialForConstituency(resource.data.location.constituencyId) ||
         (resource.data.submissionCategory == 'feedback' &&
          userDoc(request.auth.uid).constituencyId == resource.data.location.constituencyId));
      allow update: if isSignedIn() &&
        (resource.data.userId == request.auth.uid ||
         isOfficialForConstituency(resource.data.location.constituencyId) ||
         (resource.data.submissionCategory == 'feedback' &&
          userDoc(request.auth.uid).constituencyId == resource.data.location.constituencyId &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['supporterIds', 'supporterCount'])));
      allow delete: if false;
    }

    // Reference data (constituency/booth boundaries, AI-generated clusters)
    // is written by backend Cloud Functions (Admin SDK bypasses rules) or
    // manual seeding only — never directly by a client. `constituencies` is
    // public MP-roster info (name/photo/party), fine for any signed-in user
    // to read regardless of their own constituency. `booths` and `clusters`
    // carry per-constituency submission analytics, so — same as
    // `submissions` above — reads are scoped to the official who represents
    // that constituency, or a citizen whose own home constituency matches.
    match /constituencies/{constituencyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /booths/{boothId} {
      // `constituencyId == null` covers LocationService.resolveHomeBooth's
      // pincode scan during signup, which runs BEFORE the citizen's own
      // constituencyId is resolved — that discovery read must stay open,
      // same reasoning as the null-constituencyId escape hatch on
      // `submissions.create` above.
      allow read: if isSignedIn() &&
        (isOfficialForConstituency(resource.data.constituencyId) ||
         userDoc(request.auth.uid).constituencyId == null ||
         userDoc(request.auth.uid).constituencyId == resource.data.constituencyId);
      allow write: if false;
    }
    match /clusters/{clusterId} {
      allow read: if isSignedIn() &&
        (isOfficialForConstituency(resource.data.constituencyId) ||
         userDoc(request.auth.uid).constituencyId == resource.data.constituencyId);
      allow write: if false;
    }
    // Bengaluru's 369 GBA municipal wards — each tagged with its parent
    // Lok Sabha constituencyId (see seedWards.ts). Same scoped-read pattern
    // as booths/clusters; a handful of wards have a null constituencyId
    // (centroid fell outside all 543 boundaries) and are effectively
    // unreadable by constituency-scoped rules until backfilled manually.
    match /wards/{wardId} {
      allow read: if isSignedIn() &&
        (isOfficialForConstituency(resource.data.constituencyId) ||
         userDoc(request.auth.uid).constituencyId == resource.data.constituencyId);
      allow write: if false;
    }
    // Karnataka's 227 taluks (KGIS/KSRSAC official data) — the
    // ward-equivalent fine-grained unit for every constituency outside
    // Bengaluru Urban. Same scoped-read pattern as wards.
    match /taluks/{talukId} {
      allow read: if isSignedIn() &&
        (isOfficialForConstituency(resource.data.constituencyId) ||
         userDoc(request.auth.uid).constituencyId == resource.data.constituencyId);
      allow write: if false;
    }
    // District boundaries — a coarser reference/display layer only (a
    // district can span multiple constituencies, so it's never used for MP
    // routing). Not officially sensitive, safe for any signed-in user to
    // read, same as `constituencies`.
    match /districts/{districtId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // MP unique-ID + registered-email pairs used by the first-time-setup
    // and forgot-credentials flows (see functions/src/officials/) — never
    // readable by ANY client, including the MP themselves. The whole point
    // of `uniqueId` is that it's a shared secret the Cloud Functions verify
    // server-side (via Admin SDK, which bypasses these rules entirely);
    // exposing it through a client read would defeat that.
    match /mpCredentials/{constituencyId} {
      allow read, write: if false;
    }

    // Per-constituency-per-day sequence counters backing the structured
    // token id (see FirestoreService.generateTokenId) — incremented
    // directly by the citizen's own client via a transaction at ticket
    // creation time, so it can't wait on a Cloud Function round-trip. Only
    // a single numeric `count` field is ever allowed. Read access is
    // required here — the increment transaction itself does a tx.get() on
    // this doc before writing, and a denied read fails the whole
    // transaction (this used to be `allow read: if false`, which silently
    // broke every single ticket submission's token generation).
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['count']) &&
        request.resource.data.count is int &&
        request.resource.data.count > 0;
      allow delete: if false;
    }
  }
}
